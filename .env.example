# =============================================================================
# Platform Infra MCP - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- vSphere ---
VCENTER_HOST=abn-vc1.green.sophos
VCENTER_USERNAME=
VCENTER_PASSWORD=
VCENTER_IGNORE_SSL=true

# --- Atlassian (Jira + Confluence) ---
ATLASSIAN_HOST=https://sophos.atlassian.net
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=

# --- PagerDuty ---
PAGERDUTY_API_TOKEN=
PAGERDUTY_USER_EMAIL=

# --- Zabbix ---
ZABBIX_URL=
ZABBIX_API_TOKEN=
# OR use username/password:
# ZABBIX_USERNAME=
# ZABBIX_PASSWORD=

# --- MySQL ---
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# --- Channels (Internal) ---
# No additional config needed - uses SSH internally

# --- LXC ---
# LXC hosts are configured via the LXC_HOSTS variable (comma-separated)
LXC_HOSTS=
LXC_SSH_USER=
LXC_SSH_KEY_PATH=

# --- AWS Docs ---
# No credentials needed - public documentation access
