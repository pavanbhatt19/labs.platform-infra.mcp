{
  "name": "@sophos/platform-infra-mcp",
  "version": "1.0.0",
  "description": "Unified MCP server wrapping vSphere, Atlassian, PagerDuty, Zabbix, MySQL, Channels, LXC, and AWS Docs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "platform-infra-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": ["mcp", "sophos", "platform", "infrastructure"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.9",
    "mysql2": "^3.11.0",
    "ssh2": "^1.16.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ssh2": "^1.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "cpu-features": "npm:empty-npm-package@1.0.0"
  }
}
